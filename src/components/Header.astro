---
import { nav, site } from '@/config/site';

interface Props {
  /** If true, header starts transparent over the hero and becomes solid on scroll. */
  transparent?: boolean;
}

const { transparent = false } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header
  class:list={[
    'site-header',
    transparent && 'site-header--transparent',
  ]}
  data-transparent={transparent ? 'true' : 'false'}
>
  <div class="container-wide site-header__inner">
    <a href="/" class="site-header__brand" aria-label={`${site.name} — home`}>
      <img
        src="/logo-dark.png"
        alt={site.name}
        class="site-header__logo site-header__logo--dark"
        width="1250"
        height="232"
      />
      <img
        src="/logo-light.png"
        alt=""
        aria-hidden="true"
        class="site-header__logo site-header__logo--light"
        width="1250"
        height="232"
      />
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      {nav.map((item) => {
        const href = item.href.replace(/\/$/, '') || '/';
        const active =
          href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(href + '/');
        return (
          <a
            href={item.href}
            class:list={['nav-link site-header__link', active && 'is-active']}
            aria-current={active ? 'page' : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </nav>

    <a href="/contact" class="btn site-header__cta">Check Availability</a>

    <button
      type="button"
      class="site-header__menu-btn"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-menu-btn
    >
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="site-header__mobile" id="mobile-menu" data-mobile-menu hidden>
    <nav aria-label="Mobile">
      {nav.map((item) => (
        <a href={item.href} class="site-header__mobile-link">{item.label}</a>
      ))}
    </nav>
    <a href="/contact" class="btn site-header__mobile-cta">Check Availability</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-rule);
    transition: background 280ms ease, border-color 280ms ease;
  }

  .site-header--transparent {
    position: fixed;
    top: 0; left: 0; right: 0;
    background: transparent;
    border-color: transparent;
  }
  .site-header--transparent.is-scrolled {
    background: var(--color-paper);
    border-color: var(--color-rule);
  }

  .site-header__inner {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
    padding-block: 1.1rem;
  }

  .site-header__brand { grid-column: 1; display: inline-flex; align-items: center; }
  .site-header__logo {
    height: 44px;
    width: auto;
    max-width: none;
    display: block;
  }

  /* Default: show the dark-text (brand-coloured) logo. */
  .site-header__logo--light { display: none; }

  /* Over the dark hero only: swap in the light-text (still brand-coloured
     icon + tagline, white ECLIPSE MEDIA text) variant so it stays readable. */
  .site-header--transparent:not(.is-scrolled) .site-header__logo--dark { display: none; }
  .site-header--transparent:not(.is-scrolled) .site-header__logo--light { display: block; }

  .site-header__nav {
    grid-column: 2;
    display: flex;
    gap: 2.2rem;
  }

  .site-header--transparent:not(.is-scrolled) .site-header__link {
    color: var(--color-paper);
  }

  .site-header__link {
    position: relative;
    padding-block: 0.25rem;
  }

  .site-header__link.is-active::after,
  .site-header__link:hover::after {
    content: '';
    position: absolute;
    bottom: -4px; left: 0; right: 0;
    height: 1px;
    background: currentColor;
  }

  .site-header__cta { grid-column: 3; justify-self: end; }

  .site-header--transparent:not(.is-scrolled) .site-header__cta {
    background: transparent;
    border-color: var(--color-paper);
    color: var(--color-paper);
  }
  .site-header--transparent:not(.is-scrolled) .site-header__cta:hover {
    background: var(--color-paper);
    color: var(--color-ink);
  }

  .site-header__menu-btn {
    display: none;
    grid-column: 3;
    justify-self: end;
    width: 38px; height: 38px;
    background: none;
    border: none;
    padding: 8px;
    cursor: pointer;
  }
  .site-header__menu-btn span {
    display: block;
    width: 100%;
    height: 1px;
    background: var(--color-ink);
    margin: 5px 0;
    transition: transform 220ms ease, opacity 220ms ease;
  }
  .site-header--transparent:not(.is-scrolled) .site-header__menu-btn span {
    background: var(--color-paper);
  }

  .site-header__menu-btn[aria-expanded="true"] span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
  .site-header__menu-btn[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .site-header__menu-btn[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }

  .site-header__mobile {
    display: none;
    padding: 2rem 1.5rem 2.5rem;
    border-top: 1px solid var(--color-rule);
    background: var(--color-paper);
  }
  .site-header__mobile nav { display: flex; flex-direction: column; gap: 1.25rem; }
  .site-header__mobile-link {
    font-family: var(--font-display);
    font-size: 1.9rem;
    line-height: 1;
  }
  .site-header__mobile-cta { margin-top: 1.75rem; width: 100%; }

  /* Mobile */
  @media (max-width: 900px) {
    .site-header__nav,
    .site-header__cta { display: none; }
    .site-header__menu-btn { display: block; }
    .site-header__mobile[data-open="true"] { display: block; }
  }
</style>

<script>
  const header = document.querySelector('.site-header') as HTMLElement | null;
  const menuBtn = document.querySelector('[data-menu-btn]') as HTMLButtonElement | null;
  const mobile = document.querySelector('[data-mobile-menu]') as HTMLElement | null;

  if (header?.dataset.transparent === 'true') {
    const onScroll = () => {
      if (window.scrollY > 40) header.classList.add('is-scrolled');
      else header.classList.remove('is-scrolled');
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

  menuBtn?.addEventListener('click', () => {
    const open = menuBtn.getAttribute('aria-expanded') === 'true';
    menuBtn.setAttribute('aria-expanded', (!open).toString());
    if (mobile) {
      if (open) { mobile.dataset.open = 'false'; mobile.setAttribute('hidden', ''); }
      else { mobile.dataset.open = 'true'; mobile.removeAttribute('hidden'); }
    }
  });
</script>
