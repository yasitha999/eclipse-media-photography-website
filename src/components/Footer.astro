---
import { site, nav } from '@/config/site';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container-wide site-footer__inner">
    <div class="site-footer__brand">
      <img src="/logo-light.png" alt={site.name} width="1250" height="232" class="site-footer__logo" />
      <p class="site-footer__tag">
        {site.tagline}<br />
        Based in {site.addressLocality}, shooting across {site.addressRegion} & beyond.
      </p>
      <p class="site-footer__avail eyebrow">{site.availabilityMessage}</p>
    </div>

    <div class="site-footer__col">
      <h4 class="eyebrow">Explore</h4>
      <ul>
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="site-footer__col">
      <h4 class="eyebrow">Connect</h4>
      <ul>
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
        {site.instagram && <li><a href={site.instagram} target="_blank" rel="noopener">Instagram</a></li>}
      </ul>
    </div>

    <div class="site-footer__col">
      <h4 class="eyebrow">Start the conversation</h4>
      <p class="site-footer__prose">
        Ready to tell your story? I reply to every enquiry within a few hours on weekdays.
      </p>
      <a href="/contact" class="btn btn-light">Check Availability</a>
    </div>
  </div>

  <div class="site-footer__bottom container-wide">
    <p>&copy; {year} {site.name}. All images © Eclipse Media Photography.</p>
    <ul class="site-footer__legal">
      <li><a href="/privacy/">Privacy</a></li>
      <li><a href="/terms/">Terms</a></li>
    </ul>
    <p>{site.addressLocality}, {site.addressRegion}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-ink);
    color: var(--color-paper);
    padding: 5rem 0 2rem;
    margin-top: 6rem;
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.4fr;
    gap: 3rem;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }

  .site-footer__logo {
    height: 52px;
    width: auto;
    margin-bottom: 1.5rem;
  }
  .site-footer__tag {
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(250, 247, 242, 0.75);
    max-width: 320px;
  }
  .site-footer__avail {
    margin-top: 1.5rem;
    color: var(--color-accent-soft);
  }

  .site-footer__col h4 {
    color: rgba(250, 247, 242, 0.55);
    margin-bottom: 1.25rem;
  }
  .site-footer__col ul { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.7rem; }
  .site-footer__col a {
    font-size: 0.95rem;
    color: rgba(250, 247, 242, 0.85);
  }
  .site-footer__col a:hover { color: var(--color-accent-soft); }

  .site-footer__prose {
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(250, 247, 242, 0.75);
    margin-bottom: 1.5rem;
  }

  .site-footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    padding-top: 1.75rem;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: rgba(250, 247, 242, 0.5);
  }
  .site-footer__legal {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.25rem;
  }
  .site-footer__legal a {
    color: rgba(250, 247, 242, 0.6);
    text-decoration: none;
  }
  .site-footer__legal a:hover {
    color: var(--color-accent-soft);
  }

  @media (max-width: 900px) {
    .site-footer__inner { grid-template-columns: 1fr 1fr; gap: 2.5rem; }
  }
  @media (max-width: 560px) {
    .site-footer__inner { grid-template-columns: 1fr; }
    .site-footer__bottom { flex-direction: column; gap: 0.75rem; text-align: center; }
  }
</style>
