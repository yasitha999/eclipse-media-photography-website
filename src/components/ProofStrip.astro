---
/**
 * Proof signals strip — numbers + trust markers near CTAs.
 * Replace figures with real data as the business builds a track record.
 */

interface Stat { value: string; label: string }

const defaults: Stat[] = [
  { value: '200+', label: 'Weddings Documented' },
  { value: '10 yrs', label: 'Behind the Lens' },
  { value: '5.0★', label: 'Google Rated' },
  { value: 'VIC', label: 'Based · Shooting Nationwide' },
];

interface Props { stats?: Stat[] }
const { stats = defaults } = Astro.props;
---

<section class="proof-strip">
  <div class="container-wide proof-strip__inner">
    {stats.map((s) => (
      <div class="proof-strip__item">
        <div class="proof-strip__value">{s.value}</div>
        <div class="proof-strip__label eyebrow">{s.label}</div>
      </div>
    ))}
  </div>
</section>

<style>
  .proof-strip {
    border-block: 1px solid var(--color-rule);
    padding-block: 2.5rem;
    background: var(--color-paper-alt);
  }
  .proof-strip__inner {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }
  .proof-strip__value {
    font-family: var(--font-display);
    font-size: clamp(2rem, 3vw + 1rem, 3rem);
    line-height: 1;
    letter-spacing: -0.01em;
    color: var(--color-ink);
  }
  .proof-strip__label {
    margin-top: 0.75rem;
    color: var(--color-muted);
  }

  @media (max-width: 720px) {
    .proof-strip__inner { grid-template-columns: repeat(2, 1fr); gap: 2.5rem 1.5rem; }
  }
</style>
