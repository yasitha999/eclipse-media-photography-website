---
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { site } from '@/config/site';

import asideImage from '@/assets/weddings/stacie-callum/51.jpg';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: `${site.url}/contact` },
  ],
};
---

<BaseLayout
  title="Contact"
  description={`Get in touch with ${site.name} Photography — Melbourne wedding photographer. I reply to every enquiry personally, usually within a few hours.`}
  jsonLd={[breadcrumb]}
>
  <section class="contact">
    <div class="container-wide contact__grid">
      {/* -------- FORM SIDE -------- */}
      <div class="contact__form-side">
        <span class="eyebrow">Say hello</span>
        <h1 class="contact__title">Let's tell<br/><em>your story.</em></h1>
        <p class="contact__lede">
          Tell me a little about your day — your date, venue if you have one, and whatever else you'd like me to know.
          I reply to every enquiry personally, usually within a few hours on weekdays.
        </p>

        <form
          class="contact-form"
          action="https://api.web3forms.com/submit"
          method="POST"
          data-contact-form
        >
          <input type="hidden" name="access_key" value={site.web3formsAccessKey} />
          <input type="hidden" name="subject" value="New wedding enquiry via eclipsemedia.au" />
          <input type="hidden" name="from_name" value="Eclipse Media enquiry form" />
          <input type="hidden" name="redirect" value={`${site.url}/thank-you`} />
          {/* Honeypot — hidden from humans, bots fill it */}
          <input type="checkbox" name="botcheck" class="honeypot" tabindex="-1" autocomplete="off" />

          <div class="contact-form__row">
            <label class="contact-form__field">
              <span class="contact-form__label">Your name *</span>
              <input type="text" name="name" required autocomplete="name" placeholder="Sarah & Tom" />
            </label>
            <label class="contact-form__field">
              <span class="contact-form__label">Email *</span>
              <input type="email" name="email" required autocomplete="email" placeholder="you@example.com" />
            </label>
          </div>

          <div class="contact-form__row">
            <label class="contact-form__field">
              <span class="contact-form__label">Wedding date</span>
              <input type="text" name="wedding_date" placeholder="March 2026 (approximate is fine)" />
            </label>
            <label class="contact-form__field">
              <span class="contact-form__label">Venue / location</span>
              <input type="text" name="venue" placeholder="Stones of the Yarra Valley, Melbourne, TBD…" />
            </label>
          </div>

          <label class="contact-form__field">
            <span class="contact-form__label">How did you hear about me?</span>
            <select name="referral">
              <option value="">Optional</option>
              <option>Google</option>
              <option>Instagram</option>
              <option>A friend / past couple</option>
              <option>A venue / vendor</option>
              <option>Other</option>
            </select>
          </label>

          <label class="contact-form__field">
            <span class="contact-form__label">Tell me about your day *</span>
            <textarea
              name="message"
              required
              rows="6"
              placeholder="Where you're at in planning, what feels important, any questions…"
            ></textarea>
          </label>

          <p class="contact-form__privacy">
            By submitting, you consent to me replying via email. Your details are never shared.
          </p>

          <button type="submit" class="btn contact-form__submit">
            <span data-form-label>Send Enquiry</span>
          </button>

          <p class="contact-form__error" data-form-error hidden>
            Something went wrong sending your message. Please email <a href={`mailto:${site.email}`}>{site.email}</a> directly.
          </p>
        </form>
      </div>

      {/* -------- ASIDE -------- */}
      <aside class="contact__aside">
        <div class="contact__aside-img">
          <Image
            src={asideImage}
            alt="Wedding moment captured by Eclipse Media"
            widths={[600, 900, 1200]}
            sizes="(min-width: 900px) 40vw, 100vw"
            loading="eager"
            quality={78}
            format="webp"
          />
        </div>

        <div class="contact__aside-body">
          <span class="eyebrow">A quick note</span>
          <p class="contact__aside-note">
            On weekends I'm usually shooting — replies may land Monday morning. If your date is
            urgent, mention it in your message and I'll do my best to reply same-day.
          </p>

          <dl class="contact__details">
            <div>
              <dt class="eyebrow">Email</dt>
              <dd><a href={`mailto:${site.email}`}>{site.email}</a></dd>
            </div>
            {site.instagram && (
              <div>
                <dt class="eyebrow">Instagram</dt>
                <dd><a href={site.instagram} target="_blank" rel="noopener">@eclipse.media.photography</a></dd>
              </div>
            )}
            <div>
              <dt class="eyebrow">Based</dt>
              <dd>{site.addressLocality}, {site.addressRegion}</dd>
            </div>
            <div>
              <dt class="eyebrow">Availability</dt>
              <dd>{site.availabilityMessage}</dd>
            </div>
          </dl>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    padding: 10rem 0 6rem;
  }
  .contact__grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 5rem;
    align-items: start;
  }

  .contact__title {
    margin: 1rem 0 1.5rem;
  }
  .contact__title em { font-style: italic; color: var(--color-accent); }
  .contact__lede {
    font-size: 1.1rem;
    line-height: 1.65;
    color: var(--color-ink-soft);
    max-width: 38rem;
    margin-bottom: 3rem;
  }

  .contact-form { display: flex; flex-direction: column; gap: 1.5rem; }
  .contact-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .contact-form__field { display: flex; flex-direction: column; gap: 0.5rem; }
  .contact-form__label {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-muted);
  }
  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    font: inherit;
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-ink);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--color-rule);
    padding: 0.7rem 0 0.9rem;
    width: 100%;
    border-radius: 0;
    outline: none;
    transition: border-color 200ms ease;
  }
  .contact-form input::placeholder,
  .contact-form textarea::placeholder {
    color: var(--color-muted);
    opacity: 0.7;
  }
  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    border-color: var(--color-ink);
  }
  .contact-form textarea { resize: vertical; min-height: 140px; }

  .honeypot { display: none !important; }

  .contact-form__privacy {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-top: 0.5rem;
  }
  .contact-form__submit {
    align-self: flex-start;
    margin-top: 1.5rem;
    min-width: 220px;
  }
  .contact-form__submit[disabled] {
    opacity: 0.6;
    cursor: progress;
  }
  .contact-form__error {
    margin-top: 1rem;
    color: #a03030;
    font-size: 0.9rem;
  }
  .contact-form__error a { color: inherit; text-decoration: underline; }

  /* ---------- ASIDE ---------- */
  .contact__aside {
    position: sticky;
    top: 6rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }
  .contact__aside-img {
    overflow: hidden;
    aspect-ratio: 4/5;
  }
  .contact__aside-img :global(img) {
    width: 100%; height: 100%; object-fit: cover;
  }
  .contact__aside-body { padding-top: 0.5rem; }
  .contact__aside-note {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.5;
    color: var(--color-ink-soft);
    margin: 0.75rem 0 2.5rem;
    padding-left: 1rem;
    border-left: 2px solid var(--color-accent-soft);
  }

  .contact__details {
    margin: 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-rule);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .contact__details > div { display: flex; flex-direction: column; gap: 0.25rem; }
  .contact__details dt { color: var(--color-muted); }
  .contact__details dd {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.15rem;
    color: var(--color-ink);
  }

  @media (max-width: 900px) {
    .contact__grid { grid-template-columns: 1fr; gap: 3rem; }
    .contact__aside { position: static; }
    .contact-form__row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const form = document.querySelector('[data-contact-form]') as HTMLFormElement | null;
  const submitBtn = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  const label = form?.querySelector('[data-form-label]') as HTMLElement | null;
  const errorEl = form?.querySelector('[data-form-error]') as HTMLElement | null;

  // Submit via fetch so we control the redirect (Web3Forms' native redirect
  // field is unreliable on the free plan and occasionally lands on their
  // own success page). We stay on the site the whole time.
  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (submitBtn && label) {
      submitBtn.disabled = true;
      label.textContent = 'Sending…';
    }
    if (errorEl) errorEl.hidden = true;

    const formData = new FormData(form);
    // Honeypot tripped → silently fail, act as if submitted.
    if (formData.get('botcheck')) {
      window.location.href = '/thank-you';
      return;
    }

    try {
      const payload = Object.fromEntries(formData.entries());
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
        },
        body: JSON.stringify(payload),
      });
      const data = await res.json().catch(() => ({}));

      if (res.ok && data.success) {
        window.location.href = '/thank-you';
        return;
      }
      throw new Error(data.message || 'Submission failed');
    } catch (err) {
      console.error('[contact form]', err);
      if (errorEl) errorEl.hidden = false;
      if (submitBtn && label) {
        submitBtn.disabled = false;
        label.textContent = 'Send Enquiry';
      }
    }
  });
</script>
